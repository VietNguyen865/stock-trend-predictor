VM1:
sudo apt install python3 python3-pip -y
python3 --version
pip3 --version
python3 -m venv venv

#Kích hoạt môi trường ảo.
source venv/bin/activate

pip install yfinance kafka-python
git clone https://github.com/VietNguyen865/stock-trend-predictor
cd stock-trend-predictor
cd -> data_collection
nano producer.py

VM2:
sudo apt install openjdk-11-jdk -y
java -version
wget https://downloads.apache.org/kafka/3.6.1/kafka_2.13-3.6.1.tgz
tar -xzf kafka_2.13-3.6.1.tgz
mv kafka_2.13-3.6.1 /opt/kafka

#Chỉnh sửa tệp cấu hình Kafka server.
nano /opt/kafka/config/server.properties
  #broker.id=0
  #listeners=PLAINTEXT://192.168.56.102:9092  # IP của VM2
  #advertised.listeners=PLAINTEXT://192.168.56.102:9092

#Khởi động Zookeeper server trong chế độ nền.
/opt/kafka/bin/zookeeper-server-start.sh -daemon /opt/kafka/config/zookeeper.properties
#Khởi động Kafka server trong chế độ nền.
/opt/kafka/bin/kafka-server-start.sh -daemon /opt/kafka/config/server.properties
#Tạo một Kafka topic có tên stock-prices.
/opt/kafka/bin/kafka-topics.sh --create --topic stock-prices --bootstrap-server 192.168.56.102:9092 --partitions 1 --replication-factor 1

kiemtra:
ping 192.168.56.102
/opt/kafka/bin/kafka-topics.sh --list --bootstrap-server 192.168.56.102:9092

Trên VM1:
cd -> data_collection
python producer.py

Trên VM2:
/opt/kafka/bin/kafka-console-consumer.sh --bootstrap-server 192.168.56.102:9092 --topic stock-prices --from-beginning
ouput:
Sent: {'timestamp': '2025-06-03 21:52:00', 'symbol': 'AAPL', 'close_price': 150.25}
......
